# PostgreSQL connection string
DATABASE_URL=          # postgres://user:pass@localhost:5432/vicbip

# Mapbox GL JS token — get from account.mapbox.com (free tier sufficient)
MAPBOX_TOKEN=          # Get from account.mapbox.com — free tier sufficient
VITE_MAPBOX_TOKEN=     # Same value as MAPBOX_TOKEN — Vite exposes VITE_* vars to browser

# Google Custom Search API — for bridge intelligence gathering
GOOGLE_SEARCH_API_KEY= # Google Cloud Console — Custom Search API
GOOGLE_SEARCH_CX=      # Custom Search Engine ID from cse.google.com

# Google Street View Static API
STREET_VIEW_API_KEY=   # Google Cloud Console — same project as above

# VicRoads API — email traffic_requests@vicroads.vic.gov.au to request
VICROADS_API_TOKEN=    # Email traffic_requests@vicroads.vic.gov.au

# NewsAPI — optional, for Phase 2 news intelligence
NEWS_API_KEY=          # newsapi.org — optional, for Phase 2

# Backend server port
PORT=3001              # Backend port

# Node environment
NODE_ENV=development
